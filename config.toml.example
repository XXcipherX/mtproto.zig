[general]
# Route regular DC traffic via Telegram MiddleProxy transport.
# Required when using a promotion tag from @MTProxybot.
use_middle_proxy = true

# Keep media-path traffic on MiddleProxy by default, even when regular DC1..5
# traffic stays direct. Set to false if you want media to follow use_middle_proxy
# without special preference.
# force_media_middle_proxy = true

# Telemt-compatible alias for promotion tag (alternative to [server].tag).
# If both are set, [server].tag takes priority.
# ad_tag = "1234567890abcdef1234567890abcdef"

[server]
port = 443

# Override the auto-detected public IP/domain shown in startup links.
# For self-domain masking, set this to the same domain as censorship.tls_domain
# and point its DNS A record to this VPS. Tunnel deploys preserve a configured
# domain instead of replacing it with the tunnel exit IP.
# public_ip = "proxy.example.com"

# Optional IPv4 override used in MiddleProxy NAT/AES derivation.
# Useful when public_ip is a hostname or when auto-detection would pick the
# wrong IPv4 because of tunnel egress.
# middle_proxy_nat_ip = "203.0.113.10"

# 32 hex-char promotion tag from @MTProxybot (enables sponsored channels).
# tag = "1234567890abcdef1234567890abcdef"

# TCP listen queue depth. Higher values absorb connection bursts better.
# backlog = 4096

# Maximum concurrent client connections. With lazy pool allocation,
# raising this does NOT increase idle memory — slots are created on demand.
# max_connections = 65535

# Seconds to wait for the first byte from a new client before dropping.
# Keep high (300) to accommodate mobile pre-warmed connection pools.
# idle_timeout_sec = 300

# Seconds to complete TLS+MTProto handshake after first byte arrives.
# handshake_timeout_sec = 60

# MiddleProxy stream buffer size in KiB.
# Current code keeps 2 such buffers per active ME connection and 2 shared
# scratch buffers in the event loop.
# 1024 (default) is the validated minimum for reliable media downloads (Stories, video).
# Values below 1024 may cause MiddleProxyBufferOverflow on media-heavy sessions.
# Raise to 2048 for high-throughput media; values below 512 are not recommended.
# middleproxy_buffer_kb = 1024

# Runtime log verbosity: debug, info (default), warn, err.
# Set to "debug" to see DC routing, relay errors, and connection lifecycle details.
# Change takes effect on restart — no recompilation needed.
# log_level = "info"

# Max new connections per second per /24 (IPv4) or /48 (IPv6) subnet.
# Limits scanner/flood/DPI-probe impact. Default of 30 is generous for
# legitimate Telegram clients (3-6 connections at startup, then hold).
# Set to 0 to disable rate limiting entirely.
# rate_limit_per_subnet = 30

# By default, max_connections is auto-clamped to a RAM-safe estimate on startup.
# Set to true to disable this safety mechanism (only if you're sure your host
# has enough memory for the configured limits).
# unsafe_override_limits = false

[monitor]
# Optional: read only by the separate proxy-monitor service.
# The mtproto-proxy binary ignores this section.

# Bind address for the monitoring dashboard HTTP server.
# Default: 127.0.0.1 (localhost only).
# Set to "0.0.0.0" to expose the dashboard on all interfaces.
# WARNING: the dashboard has no authentication — use a firewall or
# reverse proxy with auth if binding to a public interface.
# host = "127.0.0.1"

# TCP port for the monitoring dashboard.
# port = 61208

[censorship]
# Self-domain masking domain. Point this domain's DNS A record to this VPS.
# Public :443 is handled by mtproto-proxy; ordinary HTTPS clients are forwarded
# to local Nginx on mask_port and receive 404.
tls_domain = "proxy.example.com"

# Forward unauthenticated / invalid connections to the self-domain Nginx 404 backend
# (active probing defense).
mask = true

# Local Nginx HTTPS backend. setup_masking.sh obtains a Let's Encrypt cert via
# HTTP-01 on public :80, then configures Nginx on 127.0.0.1:8443. In tunnel
# netns mode, the runtime automatically targets 10.200.200.1:8443.
mask_port = 8443

# Split ServerHello into 1-byte + 3ms delay + rest (defeats passive DPI signatures).
# Enabled by default.
# desync = true

# Dynamic Record Sizing: ramp TLS records from 1369 → 16384 bytes to mimic browser behavior.
# Improves throughput after initial handshake, may help evade statistical traffic analysis.
# drs = false

# Delegate S2C AES encryption to the Telegram DC (reduces CPU and memory usage).
# Recommended for all deployments.
fast_mode = true

[access.users]
# 32 hex-char secret (16 bytes) per user.
# Generate with: openssl rand -hex 16
user1 = "00112233445566778899aabbccddeeff"
user2 = "ffeeddccbbaa99887766554433221100"

[access.direct_users]
# Optional: users that always bypass MiddleProxy (direct DC path).
# Useful for admin/service accounts that should always use fast mode.
# Names here must match keys from [access.users].
# Value must be true/1/yes to enable.
# user1 = true
